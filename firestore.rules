// ============================================================================
// firestore.rules — Modo aberto compartilhado
// Qualquer usuário autenticado (anônimo OK) pode ler/escrever as coleções.
// ============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /sheets/{id} {
      allow read, write: if signedIn();
    }
    match /projects/{id} {
      allow read, write: if signedIn();
    }
    match /logos/{id} {
      allow read, write: if signedIn();
    }
  }
}
